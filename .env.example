# ═══════════════════════════════════════════════
# VOVPLAN — Environment Variables
# ═══════════════════════════════════════════════

# Backend
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Database
# DEV: не используется — Prisma работает на SQLite (packages/backend/prisma/dev.db),
#      Docker не нужен. PROD: PostgreSQL + PostGIS (см. infrastructure/docker-compose.yml).
DATABASE_URL="postgresql://vovplan:vovplan@localhost:5432/vovplan?schema=public"

# Redis — только для прода (очереди обработки моделей). В dev не используется.
REDIS_URL="redis://localhost:6379"

# S3 / MinIO — только для прода. В dev файлы хранятся в ./uploads (fastify-static).
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="vovplan"
S3_SECRET_KEY="vovplan123"
S3_BUCKET="vovplan-assets"
S3_REGION="us-east-1"

# JWT
JWT_SECRET="change-this-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS — origins фронтенда через запятую
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Frontend (Vite читает из этого файла: envDir = корень монорепо)
# DEV: оставить пустым — фронт ходит на бэкенд через vite-прокси (/api, /socket.io),
#      это же позволяет открывать приложение по LAN-адресу с телефона.
# PROD: абсолютный URL API, например https://api.vovplan.io
VITE_API_URL=""
VITE_S3_URL=""
