# ═══════════════════════════════════════════════
# VOVPLAN — Environment Variables
# ═══════════════════════════════════════════════

# Backend
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL + PostGIS)
DATABASE_URL="postgresql://vovplan:vovplan@localhost:5432/vovplan?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# S3 / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="vovplan"
S3_SECRET_KEY="vovplan123"
S3_BUCKET="vovplan-assets"
S3_REGION="us-east-1"

# JWT
JWT_SECRET="change-this-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Frontend
VITE_API_URL="http://localhost:4000"
VITE_S3_URL="http://localhost:9000"
