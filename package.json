{
  "name": "vovplan",
  "version": "0.1.0",
  "private": true,
  "description": "VOVPLAN — платформа совместного 3D-просмотра территориальных проектов",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
