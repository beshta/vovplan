{
  "name": "@vovplan/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --legacy-watch --delay 300ms --exec tsx src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate:pg": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:migrate:pg": "prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "db:push:pg": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:validate:pg": "prisma validate --schema prisma/schema.postgres.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.3.0",
    "@prisma/client": "^6.1.0",
    "@vovplan/shared": "*",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "nodemon": "^3.1.14",
    "prisma": "^6.1.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
