// VOVPLAN — Database Schema (PROD: PostgreSQL + PostGIS)
// Dev-схема: schema.prisma (SQLite). Клиент для прода генерируется так:
//   npx prisma generate --schema prisma/schema.postgres.prisma
//   npx prisma migrate deploy --schema prisma/schema.postgres.prisma
// Всё ниже маркера SHARED должно быть идентично в обоих файлах — проверяется в CI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── SHARED SCHEMA BELOW — идентично в schema.prisma и schema.postgres.prisma (проверяется в CI) ──

// ═══════════════════════════════════════════════
// Enums
// ═══════════════════════════════════════════════

enum ProjectRole {
  MASTER
  DESIGNER
  SUPER_SPECTATOR
  SPECTATOR
  EXTERNAL_SPECTATOR
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum UtilityType {
  WATER
  GAS
  ELECTRIC
  SEWAGE
  TELECOM
  HEAT
}

enum UtilityLocation {
  UNDERGROUND
  OVERHEAD
}

// ═══════════════════════════════════════════════
// User
// ═══════════════════════════════════════════════

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  memberships  ProjectMember[]
  models       Model3D[]
  comments     Comment[]
  objects      SceneObject[]

  @@map("users")
}
// ═══════════════════════════════════════════════
// Project
// ═══════════════════════════════════════════════

model Project {
  id          String           @id @default(cuid())
  name        String
  description String?
  bounds      Json
  centerLat   Float
  centerLng   Float
  terrainUrl  String?
  terrainMeta Json? // импорт реального рельефа: {textureUrl, widthM, heightM, minElev, maxElev, polygon, origin}
  status      ProjectStatus    @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  members     ProjectMember[]
  models      Model3D[]
  objects     SceneObject[]
  utilities   UtilityNetwork[]
  comments    Comment[]
  presets     CameraPreset[]
  shareLinks  ShareLink[]

  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole
  createdAt DateTime    @default(now())

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ═══════════════════════════════════════════════
// 3D Models (assets)
// ═══════════════════════════════════════════════

model Model3D {
  id            String      @id @default(cuid())
  projectId     String
  name          String
  glbUrl        String
  lod0Url       String?
  lod1Url       String?
  lod2Url       String?
  thumbnailUrl  String?
  boundingBox   Json
  fileSize      Int
  format        String      @default("glb")
  uploadedById  String
  createdAt     DateTime    @default(now())

  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy    User        @relation(fields: [uploadedById], references: [id])
  objects       SceneObject[]

  @@map("models_3d")
}

// ═══════════════════════════════════════════════
// Scene Objects (placed models in 3D scene)
// ═══════════════════════════════════════════════

model SceneObject {
  id          String   @id @default(cuid())
  projectId   String
  modelId     String?  // FK to Model3D — nullable until model upload is implemented (Phase 4)
  name        String
  position    Json
  rotation    Json
  scale       Json
  visible     Boolean  @default(true)
  authorId    String
  description String?  // Free-text description by the person who placed it
  docUrl      String?  // URL to external documentation/specs
  locked      Boolean  @default(true)  // Locked by default — must unlock to edit
  groundSnap  Boolean  @default(true)  // Стоит на земле: низ объекта привязан к рельефу
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  model       Model3D? @relation(fields: [modelId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])

  @@map("scene_objects")
}

// ═══════════════════════════════════════════════
// Utility Networks (engineering communications)
// ═══════════════════════════════════════════════

model UtilityNetwork {
  id          String           @id @default(cuid())
  projectId   String
  name        String
  type        UtilityType
  location    UtilityLocation
  geometry    Json
  depth       Float?
  diameter    Float?
  material    String?
  color       String           @default("#ff6600")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("utility_networks")
}

// ═══════════════════════════════════════════════
// Camera Presets (предустановленные виды камеры)
// ═══════════════════════════════════════════════

model CameraPreset {
  id        String   @id @default(cuid())
  projectId String
  name      String
  position  Json     // [x, y, z] — позиция камеры
  target    Json     // [x, y, z] — точка, на которую смотрит камера
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("camera_presets")
}

// ═══════════════════════════════════════════════
// Share Links (публичный доступ без регистрации)
// ═══════════════════════════════════════════════

model ShareLink {
  id          String    @id @default(cuid())
  projectId   String
  token       String    @unique // url-safe случайный токен
  name        String // метка, например «Для подрядчика»
  presetId    String? // стартовый вид камеры (CameraPreset.id)
  expiresAt   DateTime? // null = бессрочная
  createdById String
  createdAt   DateTime  @default(now())

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("share_links")
}

// ═══════════════════════════════════════════════
// Comments / Annotations
// ═══════════════════════════════════════════════

model Comment {
  id          String    @id @default(cuid())
  projectId   String
  objectId    String?
  anchor      Json?
  authorId    String
  text        String
  resolved    Boolean   @default(false)
  parentId    String?

  // ── 3D Annotation fields ───────────────────
  type        String?   // 'arrow' | 'line' | 'freehand' | 'pin'
  geometry    Json?     // [[x,y,z], ...] — polyline points
  color       String?   // hex color
  width       Float?    // толщина линии аннотации (мировые единицы)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])

  @@map("comments")
}
